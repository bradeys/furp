@page "/auth"

@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using Furp.Client.Authentication
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Auth</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Authenticated server call</MudText>
<MudText Class="mb-4">This page calls the protected `Furp` endpoint at <code>/api/auth/me</code> using the shared ASP.NET Core Identity cookie.</MudText>

@if (errorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@errorMessage</MudAlert>
}
else if (response is null)
{
    <MudProgressCircular Color="Color.Default" Indeterminate="true" />
}
else
{
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudText Typo="Typo.h6" GutterBottom="true">Current user</MudText>
        <MudText Class="mb-1">User ID: @response.UserId</MudText>
        <MudText Class="mb-1">User name: @response.UserName</MudText>
        <MudText>Email: @response.Email</MudText>
    </MudPaper>

    <MudTable Items="response.Claims" Dense="true" Hover="true" Elevation="0">
        <HeaderContent>
            <MudTh>Claim type</MudTh>
            <MudTh>Value</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Claim type">@context.Type</MudTd>
            <MudTd DataLabel="Value">@context.Value</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private AuthenticatedUserResponse? response;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient(FurpServerOptions.HttpClientName);
        var httpResponse = await client.GetAsync("api/auth/me");

        if (!httpResponse.IsSuccessStatusCode)
        {
            errorMessage = $"The protected server call failed with status code {(int)httpResponse.StatusCode} ({httpResponse.ReasonPhrase}).";
            return;
        }

        response = await httpResponse.Content.ReadFromJsonAsync<AuthenticatedUserResponse>();
        if (response is null)
        {
            throw new InvalidOperationException("The server returned an empty authenticated user response.");
        }
    }

    private sealed record AuthenticatedUserResponse(
        string UserId,
        string? UserName,
        string? Email,
        IReadOnlyList<AuthenticatedUserClaim> Claims);

    private sealed record AuthenticatedUserClaim(string Type, string Value);
}
